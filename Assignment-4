Write a C Program to calculate the salary of an employee given his basic pay (taken as input from the user). 
Calculate gross salary of employee. Let HRA be 10 % of basic pay and TA be 5% of basic pay. 
Let employees pay professional tax as 2% of total salary. Calculate net salary payable after deductions.


#include<stdio.h>
int main()
{
	float basic_pay, hra, ta, gross_sal, pt, net_sal;
	printf("Enter basic pay:=");
	scanf_s("%f", &basic_pay);
	hra = 0.10 * basic_pay;
	ta = 0.05 * basic_pay;
	gross_sal = hra + ta + basic_pay;
	pt = 0.02 * gross_sal;
	net_sal = gross_sal - pt;
	printf("\n Basic pay:= %.2f", basic_pay);
	printf("\n HRA:= %.2f", hra);
	printf("\n TA:= %.2f", ta);
	printf("\n Gross salary:= %.2f", gross_sal);
	printf("\n Proffesional tax to be paid:= %.2f", pt);
	printf("\n Net salary (after deductions):= %.2f", net_sal);
	return 0;
};
