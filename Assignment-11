#include<stdio.h>
#include<math.h>
int main()
{
    int n, choice, i, is_prime=1;
    long long fact=1;
    
    printf("Enter a number:=");
    scanf("%d", &n);
    
    printf("\n List of operations:=");
    printf("\n1=> Square root");
    printf("\n2=> Sqaure");
    printf("\n3=> Cube");
    printf("\n4=> Check Prime");
    printf("\n5=> Factorial");
    printf("\n6=> Prime Factors");
    
    printf("\n\n Enter your choice:=");
    scanf("%d", &choice);
    
    switch(choice)
    {
        case 1:
        if(n<0){
            printf("Square root of a negative number does not exist");
        }
        else{
            printf("Sqaure root:= %.2d", sqrt(n));
        }
        break;
        
        case 2:
        printf("Square:= %d", n*n);
        break;
        
        case 3:
        printf("Cube:= %d", n*n*n);
        break;
        
        case 4:
        if (n<=1)
        {
            is_prime=0;
        }
        for(i=2;i<=n/2; i++)
        {
            if(n%i==0){
                is_prime=0;
                break;
            }
        }
        if(is_prime==1){
            printf("%d is a Prime number", n);
        }
        else{
            printf("%d is not a Prime number", n);
        }
        break;
        
        case 5:
        if(n<0)
        {
            printf("Factorial of negative number is not defined");
        }
        else{
            for(i=1;i<=n;i++)
            {
                fact*=i;
            }
            printf("Factorial:= %d", fact);
        }
        break;
        
        case 6:
        printf("Prime factors of %d are:= ", n);
        for(i=2;i<=n;i++)
        {
            while(n%i==0){
                printf("%d", i);
                n/=i;
            }
        }
        break;
        
        default:
        printf("Invalid Choice");
    }
    return 0;
    
}

