//Assignment 2:
Write a menu driven program in C to implement the basic arithmetic operations.

#include<stdio.h>
#include<math.h>
int main()
{
	float a, b,sum,diff,mult,div;
	int op;
	char ans;
	
	//Accepting values from user
	printf("Enter the two operands:= ");
	scanf_s("%f""%f", &a, &b);
	printf("\nEnter the operation to be performed on the operands (eg. add=>1, sub=>2, mul=>3, div=>4):=");
	scanf_s("%d", &op);
	

	switch (op) {
	case 1:
		sum = a + b;
		printf("\nThe addition of the operands is:= %.2f", sum);
		break;
	case 2:
		diff = a - b;
		printf("\nThe subtraction of the operands is:= %.2f", diff);
		break;
	case 3:
		mult = a * b;
		printf("\nThe multiplication of the operands is:= %.2f", a * b);
		break;
	case 4:
		div = a / b;
		printf("\nThe division of the operands is:= %.2f", a / b);
		break;
	default:
		printf("\nInvalid input");
		break;

	}
	return 0;
}

