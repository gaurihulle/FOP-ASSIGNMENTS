#include <stdio.h>
#include<string.h>
struct student
{
    int roll_no;
    char name[50];
    float marks[3];
    float total, percentage;
};

int main() 
{
    int n,i,j;
    printf("Enter number of students:=");
    scanf("%d", &n);
    struct student s[n];

    printf("\nEnter student details:=");
    //Taking inputs:-
    for(i=0;i<n;i++)
    {
        printf("\nStudent [%d] :-", i+1);
        printf("\nRoll no:");
        scanf("%d", &s[i].roll_no);
        printf("Name:");
        scanf("%s", &s[i].name);
        printf("Marks in 3 subjects:");
        s[i].total=0;
        for(j=0;j<3;j++)
        {
            scanf("%f", &s[i].marks[j]);
            s[i].total+=s[i].marks[j];
        }
        s[i].percentage=(s[i].total/3.0);
    }
        
        //Displaying:
        printf("\nResults:=");
        for(i=0; i<n; i++)
        {
            printf("\n\nStudent [%d] :-", i+1);
            printf("\nRoll no: %d", s[i].roll_no);
            printf("\nName: %s", s[i].name);
            printf("\nMarks in 3 subjects:");
            for(j=0;j<3;j++)
            {
                printf("%.2f, ", s[i].marks[j]);
            }
            printf("\nPercentage:= %.2f ", s[i].percentage);
            
        }
    return 0;
}

